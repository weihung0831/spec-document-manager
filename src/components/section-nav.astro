---
interface Props {
  features: string;
  workflow: string;
  screenshots: string;
  faq: string;
  download: string;
  switchLang: string;
  switchLangPath: string;
}
const { features, workflow, screenshots, faq, download, switchLang, switchLangPath } = Astro.props;
---

<nav id="nav" class="fixed top-0 w-full z-50 border-b border-zinc-800/50" style="background: rgba(9,9,11,0.7); backdrop-filter: blur(12px) saturate(1.4);">
  <div class="max-w-[1400px] mx-auto px-6 h-12 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 text-sm font-bold tracking-tight text-zinc-100">
      <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1" stroke-linecap="round" stroke-linejoin="round"/><rect x="14" y="3" width="7" height="4" rx="1" stroke-linecap="round" stroke-linejoin="round"/><rect x="14" y="10" width="7" height="11" rx="1" stroke-linecap="round" stroke-linejoin="round"/><rect x="3" y="13" width="7" height="8" rx="1" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span>Spec Document Manager</span>
    </a>
    <div class="hidden md:flex items-center gap-1 text-[13px] text-zinc-400">
      <a href="#features" class="nav-link px-3 py-1.5 rounded-md hover:text-zinc-100 hover:bg-zinc-800/50 transition-all">{features}</a>
      <a href="#workflow" class="nav-link px-3 py-1.5 rounded-md hover:text-zinc-100 hover:bg-zinc-800/50 transition-all">{workflow}</a>
      <a href="#screenshots" class="nav-link px-3 py-1.5 rounded-md hover:text-zinc-100 hover:bg-zinc-800/50 transition-all">{screenshots}</a>
      <a href="#faq" class="nav-link px-3 py-1.5 rounded-md hover:text-zinc-100 hover:bg-zinc-800/50 transition-all">{faq}</a>
      <div class="w-px h-4 bg-zinc-800 mx-2"></div>
      <a href="https://github.com/weihung0831/spec-ui" target="_blank" rel="noopener" class="px-3 py-1.5 rounded-md hover:text-zinc-100 hover:bg-zinc-800/50 transition-all flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>
      <a href={switchLangPath} class="px-3 py-1.5 rounded-md hover:text-zinc-100 hover:bg-zinc-800/50 transition-all">{switchLang}</a>
      <a href="#download" class="ml-1 px-4 py-1.5 rounded-md bg-accent/10 text-accent border border-accent/20 hover:bg-accent/20 transition-all press-effect font-medium">
        {download}
      </a>
    </div>
    <button id="mobile-menu-btn" class="md:hidden text-zinc-400 hover:text-zinc-100 p-1">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
  </div>
</nav>
