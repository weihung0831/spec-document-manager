---
interface FeatureItem {
  title: string;
  desc: string;
}

interface Props {
  label: string;
  title: string;
  desc: string;
  items: FeatureItem[];
  featureIcons: string[];
}
const { label, title, desc, items, featureIcons } = Astro.props;

const titleLines = title.split('\n');
---

<div class="section-line max-w-[1400px] mx-auto"></div>
<section id="features" class="py-16 md:py-24">
  <div class="max-w-[1400px] mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-[1fr_2fr] gap-12 md:gap-20">
      <div class="md:sticky md:top-20 md:self-start">
        <span class="text-[10px] font-mono text-accent tracking-widest uppercase block mb-3">{label}</span>
        <h2 class="text-3xl md:text-4xl font-black tracking-tighter text-zinc-100 leading-tight">
          {titleLines.map((line, i) => (
            <Fragment>{line}{i < titleLines.length - 1 && <br />}</Fragment>
          ))}
        </h2>
        <p class="text-sm text-zinc-500 mt-4 max-w-[32ch] leading-relaxed">
          {desc}
        </p>
      </div>

      <div>
        {items.map((f, i) => (
          <div class:list={[
            'stagger-item feature-row grid grid-cols-[auto_auto_1fr] items-start gap-4 py-5 px-5 -mx-4 rounded-lg',
            i < items.length - 1 && 'border-b border-zinc-800/30'
          ]}>
            <span class="feature-num font-mono text-[10px] text-zinc-600 pt-2.5 transition-colors">{String(i + 1).padStart(2, '0')}</span>
            <div class="feature-icon mt-0.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><Fragment set:html={featureIcons[i]} /></svg>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-zinc-200 mb-1 transition-colors">{f.title}</h3>
              <p class="text-[12px] text-zinc-500 leading-relaxed">{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
