---
interface Props {
  badge: string;
  platforms: string;
  version: string;
  title1: string;
  title2: string;
  desc: string;
  descMd: string;
  descProgress: string;
  descCoverage: string;
  downloadBtn: string;
  scroll: string;
}
const { badge, platforms, version, title1, title2, desc, descMd, descProgress, descCoverage, downloadBtn, scroll } = Astro.props;

// Split desc on placeholders: "Write {md}, track {progress}, analyze {coverage} — ..."
const descParts = desc.split(/\{md\}|\{progress\}|\{coverage\}/)
---

<section class="md:min-h-[100dvh] relative flex flex-col md:flex-row items-center pt-24 pb-16 md:pt-12 md:pb-0 overflow-hidden">
  <!-- Grid background -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: linear-gradient(rgba(250,250,250,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(250,250,250,0.1) 1px, transparent 1px); background-size: 60px 60px;"></div>
  <!-- Glow orbs -->
  <div class="absolute top-1/4 -left-32 w-[500px] h-[500px] bg-accent/5 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-1/4 right-0 w-[400px] h-[400px] bg-accent/[0.03] rounded-full blur-[100px] pointer-events-none"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] bg-accent/[0.02] rounded-full blur-[150px] pointer-events-none"></div>
  <!-- Floating decorative elements -->
  <div class="absolute top-[20%] right-[15%] w-px h-24 bg-gradient-to-b from-transparent via-accent/20 to-transparent pointer-events-none hidden md:block" style="animation: float1 6s ease-in-out infinite;"></div>
  <div class="absolute top-[35%] right-[25%] w-px h-16 bg-gradient-to-b from-transparent via-zinc-600/30 to-transparent pointer-events-none hidden md:block" style="animation: float2 8s ease-in-out infinite;"></div>
  <div class="absolute top-[15%] right-[10%] w-2 h-2 bg-accent/20 rounded-full pointer-events-none hidden md:block" style="animation: float3 5s ease-in-out infinite;"></div>
  <div class="absolute top-[45%] right-[8%] w-1.5 h-1.5 bg-zinc-600/40 rounded-full pointer-events-none hidden md:block" style="animation: float1 7s ease-in-out infinite;"></div>

  <div class="max-w-[1400px] mx-auto px-6 w-full">
    <div class="md:pl-[8vw]">
    <!-- Version badge -->
    <div class="flex items-center gap-3 mb-8">
      <span class="inline-flex items-center gap-1.5 text-[11px] font-mono text-accent bg-accent/5 border border-accent/10 rounded-full px-3 py-1">
        <span class="w-1.5 h-1.5 bg-accent rounded-full animate-pulse"></span>
        {badge}
      </span>
      <span class="text-[11px] font-mono text-zinc-500">{platforms}</span>
      <span id="hero-version" class="text-[11px] font-mono text-accent/70">{version}</span>
    </div>

    <h1 id="hero-title" class="text-5xl md:text-7xl lg:text-[5.5rem] font-black tracking-tighter leading-[0.9] mb-6">
      <span class="block text-zinc-100">{title1}</span>
      <span class="block bg-gradient-to-r from-zinc-100 via-accent/80 to-zinc-100 bg-clip-text text-transparent" style="background-size: 200% auto; animation: shimmer 8s linear infinite;">{title2}</span>
    </h1>

    <p class="text-sm md:text-base text-zinc-400 leading-relaxed max-w-[42ch] mb-10">
      {descParts[0]}<span class="text-accent">{descMd}</span>{descParts[1]}<span class="text-cyan-400">{descProgress}</span>{descParts[2]}<span class="text-amber-400">{descCoverage}</span>{descParts[3]}
    </p>

    <div class="flex items-center gap-3">
      <a href="#download" class="magnetic-btn press-effect inline-flex items-center gap-2 bg-emerald-500 text-zinc-950 font-semibold text-sm px-6 py-2.5 rounded-lg hover:bg-emerald-400 hover:shadow-[0_0_24px_rgba(16,185,129,0.3)] transition-all" style="text-decoration:none;">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        <span id="hero-download-text">{downloadBtn}</span>
      </a>
      <a href="https://github.com/weihung0831/spec-ui" target="_blank" rel="noopener" class="magnetic-btn press-effect inline-flex items-center gap-2 text-zinc-400 border border-zinc-800 text-sm px-6 py-2.5 rounded-lg hover:text-zinc-200 hover:border-zinc-700 hover:bg-zinc-800/30 transition-all" style="text-decoration:none;">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>
    </div>

    </div>
  </div>

  <div class="mt-10 md:mt-0 md:absolute md:bottom-6 md:left-1/2 md:-translate-x-1/2 flex flex-col items-center gap-2 text-zinc-600">
    <span class="text-[10px] font-mono tracking-widest uppercase">{scroll}</span>
    <div class="w-px h-8 bg-gradient-to-b from-zinc-600 to-transparent animate-pulse"></div>
  </div>
</section>
