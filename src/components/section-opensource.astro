---
interface Props {
  label: string;
  title: string;
  desc: string;
  viewSource: string;
  reportIssue: string;
}
const { label, title, desc, viewSource, reportIssue } = Astro.props;

const githubIcon = '<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>';
---

<section class="py-16 md:py-24 border-t border-zinc-800/50">
  <div class="max-w-[1400px] mx-auto px-6">
    <div class="stagger-item spotlight-border bg-zinc-925 border border-zinc-800/30 rounded-2xl p-8 md:p-12 text-center">
      <span class="text-[10px] font-mono text-accent tracking-widest uppercase block mb-6">{label}</span>
      <div class="w-14 h-14 rounded-2xl bg-zinc-800/50 flex items-center justify-center mx-auto mb-6">
        <svg class="w-7 h-7 text-zinc-400" fill="currentColor" viewBox="0 0 24 24"><Fragment set:html={githubIcon} /></svg>
      </div>
      <h2 class="text-2xl md:text-3xl font-black tracking-tighter text-zinc-100 mb-3">{title}</h2>
      <p class="text-sm text-zinc-500 leading-relaxed max-w-[50ch] mx-auto mb-8">
        {desc}
      </p>
      <div class="flex items-center justify-center gap-3">
        <a href="https://github.com/weihung0831/spec-ui" target="_blank" rel="noopener" class="magnetic-btn press-effect inline-flex items-center gap-2 bg-zinc-100 text-zinc-950 font-semibold text-sm px-6 py-2.5 rounded-lg hover:bg-white transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><Fragment set:html={githubIcon} /></svg>
          {viewSource}
        </a>
        <a href="https://github.com/weihung0831/spec-ui/issues" target="_blank" rel="noopener" class="magnetic-btn press-effect inline-flex items-center gap-2 text-zinc-400 border border-zinc-800 text-sm px-6 py-2.5 rounded-lg hover:text-zinc-200 hover:border-zinc-700 transition-all">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          {reportIssue}
        </a>
      </div>
    </div>
  </div>
</section>
