---
interface FaqItem {
  q: string;
  a: string;
  html?: boolean;
}

interface Props {
  label: string;
  title: string;
  items: FaqItem[];
}
const { label, title, items } = Astro.props;

const titleLines = title.split('\n');
---

<section id="faq" class="py-16 md:py-24 border-t border-zinc-800/50">
  <div class="max-w-[1400px] mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-[1fr_2fr] gap-12 md:gap-20">
      <div class="md:sticky md:top-20 md:self-start">
        <span class="text-[10px] font-mono text-accent tracking-widest uppercase block mb-3">{label}</span>
        <h2 class="text-3xl md:text-4xl font-black tracking-tighter text-zinc-100 leading-tight">
          {titleLines.map((line, i) => (
            <Fragment>{line}{i < titleLines.length - 1 && <br />}</Fragment>
          ))}
        </h2>
      </div>
      <div>
        {items.map((faq, i) => (
          <div class:list={['stagger-item faq-item py-5', i < items.length - 1 && 'border-b border-zinc-800/30']}>
            <button class="faq-toggle w-full flex items-center justify-between text-left group" aria-expanded="false">
              <div class="flex items-center gap-3 pr-4">
                <span class="font-mono text-[10px] text-zinc-600">{String(i + 1).padStart(2, '0')}</span>
                <h3 class="text-sm font-semibold text-zinc-200 group-hover:text-white transition-colors">{faq.q}</h3>
              </div>
              <svg class="faq-chevron w-4 h-4 text-zinc-600 flex-shrink-0 transition-transform duration-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="faq-answer overflow-hidden max-h-0 transition-all duration-300">
              {faq.html
                ? <div class="text-[13px] text-zinc-500 leading-relaxed pt-3 pl-8 space-y-2" set:html={faq.a} />
                : <p class="text-[13px] text-zinc-500 leading-relaxed pt-3 pl-8">{faq.a}</p>
              }
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
