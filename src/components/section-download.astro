---
interface Props {
  label: string;
  title: string;
  desc: string;
  detecting: string;
  recommended: string;
  macAppleSilicon: string;
  macIntel: string;
  windows: string;
  allVersions: string;
  macArmUrl: string;
  macIntelUrl: string;
  winUrl: string;
  version: string;
}
const { label, title, desc, detecting, recommended, macAppleSilicon, macIntel, windows, allVersions, macArmUrl, macIntelUrl, winUrl, version } = Astro.props;

const titleLines = title.split('\n');
---

<section id="download" class="py-16 md:py-24 border-t border-zinc-800/50">
  <div class="max-w-[1400px] mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-[1fr_1fr] gap-12 md:gap-20 items-center">
      <div class="md:pl-[4vw]">
        <span class="text-[10px] font-mono text-accent tracking-widest uppercase block mb-3">{label}</span>
        <h2 class="text-3xl md:text-5xl font-black tracking-tighter text-zinc-100 leading-tight mb-4">
          {titleLines.map((line, i) => (
            <Fragment>{line}{i < titleLines.length - 1 && <br />}</Fragment>
          ))}
        </h2>
        <p class="text-sm text-zinc-500 leading-relaxed max-w-[42ch]">
          {desc}
        </p>
      </div>

      <div class="space-y-3">
        <a id="download-btn" href={macArmUrl} data-mac-arm={macArmUrl} data-mac-intel={macIntelUrl} data-win={winUrl} class="stagger-item spotlight-border magnetic-btn press-effect download-card flex items-center justify-between bg-zinc-900 border border-zinc-800/40 rounded-xl px-6 py-4 hover:border-accent/30 transition-all group">
          <div class="flex items-center gap-4">
            <span class="font-mono text-[10px] text-zinc-600">01</span>
            <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            </div>
            <div>
              <span id="download-btn-text" class="text-sm font-semibold text-zinc-100 block">{detecting}</span>
              <span class="text-[11px] font-mono text-zinc-600">{recommended}{version && ` · v${version}`}</span>
            </div>
          </div>
          <svg class="w-4 h-4 text-zinc-600 group-hover:text-accent group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>

        <a id="dl-mac" href={macArmUrl} class="stagger-item spotlight-border magnetic-btn press-effect flex items-center justify-between bg-zinc-925 border border-zinc-800/30 rounded-xl px-6 py-3.5 hover:border-zinc-700 transition-all group">
          <div class="flex items-center gap-3">
            <span class="font-mono text-[10px] text-zinc-600">02</span>
            <svg class="w-4 h-4 text-zinc-500" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            <span class="text-sm text-zinc-400">{macAppleSilicon}</span>
          </div>
          <svg class="w-3.5 h-3.5 text-zinc-700 group-hover:text-zinc-500 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        </a>

        <a id="dl-mac-intel" href={macIntelUrl} class="stagger-item spotlight-border magnetic-btn press-effect flex items-center justify-between bg-zinc-925 border border-zinc-800/30 rounded-xl px-6 py-3.5 hover:border-zinc-700 transition-all group">
          <div class="flex items-center gap-3">
            <span class="font-mono text-[10px] text-zinc-600">03</span>
            <svg class="w-4 h-4 text-zinc-500" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            <span class="text-sm text-zinc-400">{macIntel}</span>
          </div>
          <svg class="w-3.5 h-3.5 text-zinc-700 group-hover:text-zinc-500 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        </a>

        <a id="dl-win" href={winUrl} class="stagger-item spotlight-border magnetic-btn press-effect flex items-center justify-between bg-zinc-925 border border-zinc-800/30 rounded-xl px-6 py-3.5 hover:border-zinc-700 transition-all group">
          <div class="flex items-center gap-3">
            <span class="font-mono text-[10px] text-zinc-600">04</span>
            <svg class="w-4 h-4 text-zinc-500" fill="currentColor" viewBox="0 0 24 24"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/></svg>
            <span class="text-sm text-zinc-400">{windows}</span>
          </div>
          <svg class="w-3.5 h-3.5 text-zinc-700 group-hover:text-zinc-500 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        </a>

        <a href="https://github.com/weihung0831/spec-ui/releases" target="_blank" rel="noopener" class="stagger-item spotlight-border magnetic-btn press-effect flex items-center justify-between bg-zinc-925 border border-zinc-800/30 rounded-xl px-6 py-3.5 hover:border-zinc-700 transition-all group">
          <div class="flex items-center gap-3">
            <span class="font-mono text-[10px] text-zinc-600">05</span>
            <svg class="w-4 h-4 text-zinc-600" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            <span class="text-sm text-zinc-500 group-hover:text-zinc-300 transition-colors">{allVersions}</span>
          </div>
          <svg class="w-3.5 h-3.5 text-zinc-700 group-hover:text-zinc-500 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>
