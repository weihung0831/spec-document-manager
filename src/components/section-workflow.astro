---
interface WorkflowStep {
  title: string;
  desc: string;
  tag: string;
}

interface Props {
  label: string;
  title: string;
  steps: WorkflowStep[];
}
const { label, title, steps } = Astro.props;

// Step icons (language-independent)
const stepIcons = [
  '<path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>',
  '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>',
  '<path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>',
];
---

<section id="workflow" class="py-16 md:py-24 border-t border-zinc-800/50 relative overflow-hidden">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] bg-accent/[0.03] rounded-full blur-[100px] pointer-events-none"></div>
  <div class="max-w-[1400px] mx-auto px-6">
    <div class="text-center mb-14">
      <span class="text-[10px] font-mono text-accent tracking-widest uppercase block mb-3">{label}</span>
      <h2 class="text-3xl md:text-4xl font-black tracking-tighter text-zinc-100">{title}</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {steps.map((s, i) => (
        <div class="stagger-item spotlight-border bg-zinc-925 border border-zinc-800/30 rounded-2xl p-6 md:p-8 relative group hover:border-accent/20 transition-all">
          <div class="flex items-center gap-4 mb-5">
            <div class="w-10 h-10 rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0 group-hover:bg-accent/20 transition-colors">
              <span class="text-sm font-black text-accent font-mono">{i + 1}</span>
            </div>
            {i < steps.length - 1 && <div class="hidden md:block flex-1 h-px bg-gradient-to-r from-accent/20 to-transparent"></div>}
          </div>
          <h3 class="text-base font-bold text-zinc-100 mb-2 group-hover:text-white transition-colors">{s.title}</h3>
          <p class="text-[13px] text-zinc-500 leading-relaxed">{s.desc}</p>
          <div class="mt-5 pt-4 border-t border-zinc-800/30 flex items-center gap-2">
            <svg class="w-3.5 h-3.5 text-accent/50" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><Fragment set:html={stepIcons[i]} /></svg>
            <span class="text-[11px] text-zinc-600 font-mono">{s.tag}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
